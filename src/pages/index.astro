      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .casino-card p {
      color: #666;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .casino-card a {
      color: #667eea;
      text-decoration: none;
      font-weight: 600;
    }

    .casino-card a:hover {
