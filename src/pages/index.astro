      line-height: 1.6;
    }

    .casino-grid {
      max-width: 1200px;
      margin: 2rem auto 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      padding: 0 2rem;
    }

    .casino-card {
