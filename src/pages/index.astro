---
import BaseLayout from '../layouts/BaseLayout.astro';
import CasinoCard from '../components/casino/CasinoCard';
import EmailCaptureForm from '../components/forms/EmailCaptureForm';
import { getSessionUser } from '../lib/auth';
import { getCached } from '../lib/cache';
import { query } from '../lib/db';

export const prerender = false;

function formatIntelType(itemType: string) {
  return itemType
    .split('_')
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
}

function getIntelBadgeColor(itemType: string) {
  const key = itemType.toLowerCase();
  if (key === 'free_sc') return { background: 'rgba(16, 185, 129, 0.14)', color: 'var(--accent-green)' };
  if (key === 'flash_sale' || key === 'promo_code') return { background: 'rgba(59, 130, 246, 0.14)', color: 'var(--accent-blue)' };
  if (key === 'alert') return { background: 'rgba(245, 158, 11, 0.14)', color: 'var(--accent-yellow)' };
  if (key === 'playthrough_deal') return { background: 'rgba(124, 58, 237, 0.12)', color: '#6d28d9' };
  if (key === 'platform_warning') return { background: 'rgba(239, 68, 68, 0.14)', color: 'var(--accent-red)' };
  return { background: 'rgba(156, 163, 175, 0.12)', color: 'var(--text-muted)' };
}

function formatTimeAgo(value: string) {
  const timestamp = new Date(value).getTime();
  const diffMs = timestamp - Date.now();
  const minute = 60 * 1000;
  const hour = 60 * minute;
  const day = 24 * hour;
  const formatter = new Intl.RelativeTimeFormat('en', { numeric: 'auto' });

  if (Math.abs(diffMs) >= day) {
    return formatter.format(Math.round(diffMs / day), 'day');
  }

  if (Math.abs(diffMs) >= hour) {
    return formatter.format(Math.round(diffMs / hour), 'hour');
  }

  return formatter.format(Math.round(diffMs / minute), 'minute');
}

const user = await getSessionUser(Astro.request);

async function safeHomepageQuery<T>(label: string, fetcher: () => Promise<T[]>) {
  try {
    return await fetcher();
  } catch (error) {
    console.error(`homepage section failed: ${label}`, error);
    return [] as T[];
  }
}

const [topCasinos, pulloutAlerts, banAlerts, intelTeaserItems] = await Promise.all([
  safeHomepageQuery('top-casinos', () =>
    getCached('homepage:top-casinos', 15 * 60 * 1000, async () =>
      query<{
        id: number;
        slug: string;
        name: string;
        tier: string;
        promoban_risk: string;
        has_live_games: boolean;
        redemption_speed_desc: string | null;
        daily_bonus_desc: string | null;
        has_affiliate_link: boolean;
        affiliate_link_url: string | null;
      }>(
        `SELECT
          id,
          slug,
          name,
          tier,
          promoban_risk,
          has_live_games,
          redemption_speed_desc,
          daily_bonus_desc,
          has_affiliate_link,
          affiliate_link_url
        FROM casinos
        WHERE tier IN ('S', 'A')
          AND is_excluded = false
          AND source = 'admin'
        ORDER BY tier ASC, name ASC
        LIMIT 6`,
      )),
  ),
  safeHomepageQuery('pullout-alerts', () =>
    getCached('homepage:pullout-alerts', 5 * 60 * 1000, () =>
      query<{
        id: number;
        state_code: string;
        created_at: string;
        name: string | null;
        slug: string | null;
      }>(
        `SELECT spa.id, spa.state_code, spa.created_at, c.name, c.slug
        FROM state_pullout_alerts spa
        LEFT JOIN casinos c ON c.id = spa.casino_id
        WHERE spa.created_at > NOW() - INTERVAL '30 days'
        ORDER BY spa.created_at DESC
        LIMIT 5`,
      )),
  ),
  safeHomepageQuery('ban-upticks', () =>
    getCached('homepage:ban-upticks', 5 * 60 * 1000, () =>
      query<{
        id: number;
        created_at: string;
        name: string;
        slug: string;
      }>(
        `SELECT bua.id, bua.created_at, c.name, c.slug
        FROM ban_uptick_alerts bua
        JOIN casinos c ON c.id = bua.casino_id
        WHERE bua.is_active = true
        ORDER BY bua.created_at DESC
        LIMIT 5`,
      )),
  ),
  safeHomepageQuery('intel-teaser', () =>
    getCached('homepage:intel-teaser', 2 * 60 * 1000, () =>
      query<{
        id: number;
        item_type: string;
        title: string;
        casino_id: number | null;
        created_at: string;
        casino_name: string | null;
      }>(
        `SELECT dii.id, dii.item_type, dii.title, dii.casino_id, dii.created_at, c.name AS casino_name
        FROM discord_intel_items dii
        LEFT JOIN casinos c ON c.id = dii.casino_id
        WHERE dii.is_published = true
          AND (dii.expires_at IS NULL OR dii.expires_at > NOW())
        ORDER BY dii.created_at DESC
        LIMIT 3`,
      )),
  ),
]);

const joinedRows =
  user && topCasinos.length > 0
    ? await query<{ casino_id: number }>(
        `SELECT DISTINCT casino_id
        FROM ledger_entries
        WHERE user_id = $1
          AND casino_id = ANY($2::int[])`,
        [user.userId, topCasinos.map((casino) => casino.id)],
      )
    : [];

const joinedSet = new Set(joinedRows.map((row) => row.casino_id));
const homepageCasinos = topCasinos.map((casino) => ({
  ...casino,
  joined: joinedSet.has(casino.id),
}));
---

<BaseLayout
  title="SweepsIntel"
  description="Track your sweepstakes casinos in one place."
  user={user}
  currentPath={Astro.url.pathname}
>
  <div class="page-shell page-stack">
    <section class="surface-card" style="padding:2rem;">
      <div style="display:grid;gap:2rem;">
        <div style="display:grid;gap:1rem;">
          <span style="display:inline-flex;width:fit-content;padding:.45rem .75rem;border-radius:999px;background:rgba(37,99,235,.1);color:var(--color-primary);font-weight:700;text-transform:uppercase;font-size:.78rem;">
            Casino intelligence platform
          </span>
          <h1 class="section-title" style="font-size:clamp(2.6rem,8vw,4.8rem);line-height:.95;margin:0;">
            Track your sweepstakes casinos in one place.
          </h1>
          <p class="muted" style="max-width:44rem;line-height:1.8;">
            Use the public directory to compare casinos, then switch into your tracker for daily claims, redemption timing, and community intel.
          </p>
          <div style="display:flex;gap:.85rem;flex-wrap:wrap;">
            <a href="/getting-started" style="display:inline-flex;padding:.95rem 1.2rem;border-radius:999px;background:var(--color-primary);color:var(--text-primary);text-decoration:none;font-weight:700;">
              Start earning today →
            </a>
            <a href="/tracker" style="display:inline-flex;padding:.95rem 1.2rem;border-radius:999px;border:1px solid var(--color-border);background:var(--color-surface);color:var(--color-ink);text-decoration:none;font-weight:700;">
              Open tracker →
            </a>
          </div>
        </div>
        {!user ? <EmailCaptureForm client:load source="homepage_banner" /> : null}
      </div>
    </section>

    {pulloutAlerts.length > 0 || banAlerts.length > 0 ? (
      <section class="surface-card" style="padding:1.5rem;display:grid;gap:1.25rem;">
        {pulloutAlerts.length > 0 ? (
          <div style="display:grid;gap:.75rem;">
            <div style="display:flex;justify-content:space-between;gap:1rem;align-items:center;flex-wrap:wrap;">
              <h2 class="section-title" style="font-size:1.4rem;margin:0;">⚠️ Recent state pullout alerts</h2>
              <a href="/states" style="font-weight:700;">View all →</a>
            </div>
            <ul style="margin:0;padding-left:1.15rem;display:grid;gap:.55rem;">
              {pulloutAlerts.map((alert) => (
                <li>
                  {alert.slug ? <a href={`/casinos/${alert.slug}`}>{alert.name ?? 'Unknown casino'}</a> : alert.name ?? 'Unknown casino'} stopped accepting in {alert.state_code} - {new Date(alert.created_at).toLocaleDateString()}
                </li>
              ))}
            </ul>
          </div>
        ) : null}

        {banAlerts.length > 0 ? (
          <div style="display:grid;gap:.75rem;">
            <h2 class="section-title" style="font-size:1.4rem;margin:0;">🚩 Active ban uptick warnings</h2>
            <ul style="margin:0;padding-left:1.15rem;display:grid;gap:.55rem;">
              {banAlerts.map((alert) => (
                <li>
                  Elevated ban reports at <a href={`/casinos/${alert.slug}`}>{alert.name}</a>
                </li>
              ))}
            </ul>
          </div>
        ) : null}
      </section>
    ) : null}

    {intelTeaserItems.length > 0 ? (
      <section class="surface-card" style="padding:1.5rem;display:grid;gap:1rem;">
        <div>
          <h2 class="section-title" style="margin:0 0 .4rem;">Today&apos;s Community Intel</h2>
          <p class="muted" style="margin:0;">Recent public intel from the community feed.</p>
        </div>
        <div style="display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));">
          {intelTeaserItems.map((item) => {
            const badge = getIntelBadgeColor(item.item_type);
            return (
              <article style="border:1px solid var(--color-border);border-radius:1.25rem;padding:1rem;display:grid;gap:.75rem;background:var(--color-surface);">
                <div style="display:flex;justify-content:space-between;gap:.75rem;align-items:flex-start;">
                  <span style={`display:inline-flex;width:fit-content;padding:.3rem .6rem;border-radius:999px;font-weight:700;font-size:.8rem;background:${badge.background};color:${badge.color};`}>
                    {formatIntelType(item.item_type)}
                  </span>
                  <span class="muted" style="font-size:.85rem;">{formatTimeAgo(item.created_at)}</span>
                </div>
                <strong style="font-size:1rem;line-height:1.4;">{item.title}</strong>
                <span class="muted">{item.casino_name ?? 'Community-wide'}</span>
              </article>
            );
          })}
        </div>
      </section>
    ) : null}

    <section>
      <div style="display:flex;justify-content:space-between;gap:1rem;align-items:end;flex-wrap:wrap;">
        <div>
          <h2 class="section-title" style="margin:0 0 .5rem;">Top casinos</h2>
          <p class="muted" style="margin:0;">S-tier and A-tier casinos first.</p>
        </div>
        <a href="/casinos" style="font-weight:700;">Browse all casinos →</a>
      </div>
      <div style="display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));margin-top:1rem;">
        {homepageCasinos.map((casino) => (
          <CasinoCard
            client:load
            casino={casino}
            destination={
              casino.has_affiliate_link && !casino.joined
                ? {
                    kind: 'affiliate',
                    href: null,
                    fallbackUrl: casino.affiliate_link_url,
                  }
                : {
                    kind: 'profile',
                    href: `/casinos/${casino.slug}`,
                    fallbackUrl: null,
                  }
            }
            referrerSource="homepage"
          />
        ))}
      </div>
    </section>

    <section class="surface-card" style="padding:1.5rem;display:grid;gap:.65rem;">
      <h2 class="section-title" style="font-size:1.6rem;margin:0;">Join the community</h2>
      <p class="muted" style="margin:0;">
        Dogbear&apos;s SweepstakeSideHustle Discord is still the fastest way to hear the raw chatter.
      </p>
      <a
        href="https://discord.gg/9CgSgJHFu8"
        target="_blank"
        rel="noopener noreferrer"
        style="font-weight:700;"
      >
        Join Discord →
      </a>
    </section>
  </div>
</BaseLayout>

