---
import AdminCasinoForm from '../../../components/admin/AdminCasinoForm';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getSessionUser } from '../../../lib/auth';
import { query } from '../../../lib/db';

export const prerender = false;
const user = await getSessionUser(Astro.request);
if (!user) return Astro.redirect('/');
if (!user.isAdmin) return new Response('Forbidden', { status: 403 });

const casinoId = Number(Astro.params.id);
const casinos = await query<any>('SELECT * FROM casinos WHERE id = $1 LIMIT 1', [casinoId]);
const casino = casinos[0];
if (!casino) return new Response('Not found', { status: 404 });

const providers = await query<{ id: number; name: string }>('SELECT id, name FROM game_providers ORDER BY name ASC');
const selectedProviders = await query<{ provider_id: number }>('SELECT provider_id FROM casino_live_game_providers WHERE casino_id = $1', [casinoId]);
const games = await query<any>(
  `SELECT id, provider_id, game_name, game_type, is_cross_wash_relevant, confidence, status
  FROM casino_game_availability
  WHERE casino_id = $1
  ORDER BY game_name ASC`,
  [casinoId],
);
---

<BaseLayout title={`${casino.name} | Admin`} user={user} currentPath={Astro.url.pathname}>
  <div class="page-shell page-stack admin-shell">
    <AdminCasinoForm
      client:load
      mode="edit"
      casino={casino}
      providers={providers}
      selectedProviders={selectedProviders.map((row) => row.provider_id)}
      games={games}
    />
  </div>
</BaseLayout>
