---
import SessionGate from '../components/auth/SessionGate';
import DashboardTracker from '../components/dashboard/DashboardTracker';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSessionUser } from '../lib/auth';
import { getCached } from '../lib/cache';
import { query } from '../lib/db';
import { getTrackerStatus } from '../lib/tracker';

export const prerender = false;

const user = await getSessionUser(Astro.request);

let initialData = {
  casinos: [],
  streakClaims: [],
  alerts: [],
  joinedCasinoIds: [],
};

let initialSummary = {
  dailyGoalUsd: 5,
  weeklyGoalUsd: null,
  momentumPeriod: 'daily',
  momentumStyle: 'rainbow',
  kpiCards: ['sc_earned', 'usd_earned', 'purchases', 'pending_redemptions'],
  scEarnedToday: 0,
  usdEarnedToday: 0,
  scEarnedWeek: 0,
  usdEarnedWeek: 0,
  purchaseCountToday: 0,
  purchaseUsdToday: 0,
  pendingRedemptionsCount: 0,
  pendingRedemptionsUsd: 0,
  bestPerformerName: null,
  bestPerformerSc: 0,
  claimStreakDays: 0,
  dailyVelocityPct: 0,
};

let initialDiscovery = {
  homeState: null,
  casinos: [],
};

let trackerError: string | null = null;

async function safeDashboardQuery<T>(label: string, fetcher: () => Promise<T>, fallback: T) {
  try {
    return await fetcher();
  } catch (error) {
    console.error(`dashboard query failed: ${label}`, error);
    return fallback;
  }
}

function parseJsonish(value: unknown) {
  if (value === null || value === undefined) return null;
  if (typeof value !== 'string') return value;
  try {
    return JSON.parse(value);
  } catch {
    return value;
  }
}

function normalizeKpiCards(value: unknown) {
  const parsed = parseJsonish(value);
  const allowed = new Set([
    'sc_earned',
    'usd_earned',
    'purchases',
    'pending_redemptions',
    'best_performer',
    'claim_streak',
    'daily_velocity',
  ]);
  if (!Array.isArray(parsed)) {
    return ['sc_earned', 'usd_earned', 'purchases', 'pending_redemptions'];
  }
  const filtered = parsed.filter(
    (item): item is string => typeof item === 'string' && allowed.has(item),
  );
  return filtered.length >= 3 ? filtered.slice(0, 4) : ['sc_earned', 'usd_earned', 'purchases', 'pending_redemptions'];
}

function normalizeMomentumStyle(value: unknown) {
  const parsed = parseJsonish(value);
  const allowed = new Set(['rainbow', 'green', 'blue', 'amber', 'purple']);
  return typeof parsed === 'string' && allowed.has(parsed) ? parsed : 'rainbow';
}

function localDateKey(value: Date, timezone: string) {
  const parts = new Intl.DateTimeFormat('en-US', {
    timeZone: timezone,
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).formatToParts(value);
  const year = parts.find((part) => part.type === 'year')?.value ?? '0000';
  const month = parts.find((part) => part.type === 'month')?.value ?? '00';
  const day = parts.find((part) => part.type === 'day')?.value ?? '00';
  return `${year}-${month}-${day}`;
}

if (user) {
  try {
    initialData = await getTrackerStatus(user.userId);
  } catch (error) {
    console.error('dashboard status failed', error);
    trackerError = 'Your session is valid, but dashboard data could not be loaded right now.';
  }

  const [settings, earnings, weeklyEarnings, purchases, pending, bestPerformer, trackedDailyCount, streakCounts, velocity] = await Promise.all([
    safeDashboardQuery(
      'settings',
      () =>
        query<{
          daily_goal_usd: number | string | null;
          weekly_goal_usd: number | string | null;
          momentum_period: string | null;
          home_state: string | null;
          kpi_cards: unknown;
          momentum_style: unknown;
        }>(
          `SELECT daily_goal_usd, weekly_goal_usd, momentum_period, home_state, kpi_cards, momentum_style
          FROM user_settings
          WHERE user_id = $1
          LIMIT 1`,
          [user.userId],
        ),
      [],
    ),
    safeDashboardQuery(
      'earnings',
      () =>
        query<{
          sc_earned_today: number | string | null;
          usd_earned_today: number | string | null;
        }>(
          `SELECT
            COALESCE(SUM(COALESCE(le.sc_amount, 0)), 0) AS sc_earned_today,
            COALESCE(SUM(COALESCE(le.sc_amount, 0) * COALESCE(c.sc_to_usd_ratio, 1)), 0) AS usd_earned_today
          FROM ledger_entries le
          LEFT JOIN casinos c ON c.id = le.casino_id
          WHERE le.user_id = $1
            AND le.entry_type IN ('daily', 'free_sc')
            AND (COALESCE(le.entry_at, le.entry_date::timestamptz) AT TIME ZONE $2)::date = (NOW() AT TIME ZONE $2)::date`,
          [user.userId, user.timezone],
        ),
      [],
    ),
    safeDashboardQuery(
      'weekly-earnings',
      () =>
        query<{
          sc_earned_week: number | string | null;
          usd_earned_week: number | string | null;
        }>(
          `SELECT
            COALESCE(SUM(COALESCE(le.sc_amount, 0)), 0) AS sc_earned_week,
            COALESCE(SUM(COALESCE(le.sc_amount, 0) * COALESCE(c.sc_to_usd_ratio, 1)), 0) AS usd_earned_week
          FROM ledger_entries le
          LEFT JOIN casinos c ON c.id = le.casino_id
          WHERE le.user_id = $1
            AND le.entry_type IN ('daily', 'free_sc', 'purchase_credit')
            AND COALESCE(le.entry_at, le.entry_date::timestamptz) >= NOW() - INTERVAL '7 days'`,
          [user.userId],
        ),
      [],
    ),
    safeDashboardQuery(
      'purchases',
      () =>
        query<{
          purchase_count_today: number | string | null;
          purchase_usd_today: number | string | null;
        }>(
          `SELECT
            COUNT(*)::int AS purchase_count_today,
            COALESCE(SUM(ABS(COALESCE(usd_amount, 0))), 0) AS purchase_usd_today
          FROM ledger_entries
          WHERE user_id = $1
            AND entry_type = 'purchase'
            AND (COALESCE(entry_at, entry_date::timestamptz) AT TIME ZONE $2)::date = (NOW() AT TIME ZONE $2)::date`,
          [user.userId, user.timezone],
        ),
      [],
    ),
    safeDashboardQuery(
      'pending',
      () =>
        query<{
          pending_redemptions_count: number | string | null;
          pending_redemptions_usd: number | string | null;
        }>(
          `SELECT
            COUNT(*)::int AS pending_redemptions_count,
            COALESCE(SUM(usd_amount), 0) AS pending_redemptions_usd
          FROM redemptions
          WHERE user_id = $1
            AND status = 'pending'`,
          [user.userId],
        ),
      [],
    ),
    safeDashboardQuery(
      'best-performer',
      () =>
        query<{
          name: string;
          net_sc: number | string | null;
        }>(
          `SELECT
            c.name,
            COALESCE(SUM(COALESCE(le.sc_amount, 0)), 0) AS net_sc
          FROM ledger_entries le
          JOIN casinos c ON c.id = le.casino_id
          WHERE le.user_id = $1
            AND le.entry_type IN ('daily', 'free_sc', 'purchase_credit', 'adjustment')
          GROUP BY c.id, c.name
          ORDER BY net_sc DESC, c.name ASC
          LIMIT 1`,
          [user.userId],
        ),
      [],
    ),
    safeDashboardQuery(
      'tracked-daily-count',
      () =>
        query<{ tracked_daily_count: number | string | null }>(
          `SELECT COUNT(*)::int AS tracked_daily_count
          FROM user_casino_settings
          WHERE user_id = $1
            AND removed_at IS NULL
            AND COALESCE(no_daily_reward, false) = false`,
          [user.userId],
        ),
      [],
    ),
    safeDashboardQuery(
      'claim-streak',
      () =>
        query<{
          claim_date: string;
          claim_count: number | string | null;
        }>(
          `SELECT
            (COALESCE(reset_period_start, claimed_at) AT TIME ZONE $2)::date AS claim_date,
            COUNT(DISTINCT casino_id)::int AS claim_count
          FROM daily_bonus_claims
          WHERE user_id = $1
            AND COALESCE(reset_period_start, claimed_at) >= NOW() - INTERVAL '45 days'
          GROUP BY claim_date
          ORDER BY claim_date DESC`,
          [user.userId, user.timezone],
        ),
      [],
    ),
    safeDashboardQuery(
      'daily-velocity',
      () =>
        query<{
          sc_today: number | string | null;
          sc_30d: number | string | null;
        }>(
          `SELECT
            COALESCE(SUM(
              CASE
                WHEN (COALESCE(le.entry_at, le.entry_date::timestamptz) AT TIME ZONE $2)::date = (NOW() AT TIME ZONE $2)::date
                  THEN COALESCE(le.sc_amount, 0)
                ELSE 0
              END
            ), 0) AS sc_today,
            COALESCE(SUM(
              CASE
                WHEN COALESCE(le.entry_at, le.entry_date::timestamptz) >= NOW() - INTERVAL '30 days'
                  THEN COALESCE(le.sc_amount, 0)
                ELSE 0
              END
            ), 0) AS sc_30d
          FROM ledger_entries le
          WHERE le.user_id = $1
            AND le.entry_type IN ('daily', 'free_sc', 'purchase_credit')`,
          [user.userId, user.timezone],
        ),
      [],
    ),
  ]);

  const settingsRow = settings[0];
  const earningsRow = earnings[0];
  const weeklyEarningsRow = weeklyEarnings[0];
  const purchasesRow = purchases[0];
  const pendingRow = pending[0];
  const bestPerformerRow = bestPerformer[0];
  const trackedDailyCountRow = trackedDailyCount[0];
  const velocityRow = velocity[0];
  const trackedDailyTotal = Number(trackedDailyCountRow?.tracked_daily_count ?? 0);
  const streakCountByDate = new Map(
    streakCounts.map((row) => [row.claim_date, Number(row.claim_count ?? 0)]),
  );
  let claimStreakDays = 0;
  if (trackedDailyTotal > 0) {
    let cursor = new Date();
    while (claimStreakDays < 45) {
      const localDate = localDateKey(cursor, user.timezone);
      if ((streakCountByDate.get(localDate) ?? 0) < trackedDailyTotal) {
        break;
      }
      claimStreakDays += 1;
      cursor.setDate(cursor.getDate() - 1);
    }
  }
  const scToday = Number(velocityRow?.sc_today ?? 0);
  const sc30d = Number(velocityRow?.sc_30d ?? 0);
  const avg30d = sc30d > 0 ? sc30d / 30 : 0;
  const dailyVelocityPct = avg30d > 0 ? ((scToday / avg30d) - 1) * 100 : scToday > 0 ? 100 : 0;

  initialSummary = {
    dailyGoalUsd: Number(settingsRow?.daily_goal_usd ?? 5),
    weeklyGoalUsd:
      settingsRow?.weekly_goal_usd === null || settingsRow?.weekly_goal_usd === undefined
        ? null
        : Number(settingsRow.weekly_goal_usd),
    momentumPeriod: settingsRow?.momentum_period === 'weekly' ? 'weekly' : 'daily',
    momentumStyle: normalizeMomentumStyle(settingsRow?.momentum_style),
    kpiCards: normalizeKpiCards(settingsRow?.kpi_cards),
    scEarnedToday: Number(earningsRow?.sc_earned_today ?? 0),
    usdEarnedToday: Number(earningsRow?.usd_earned_today ?? 0),
    scEarnedWeek: Number(weeklyEarningsRow?.sc_earned_week ?? 0),
    usdEarnedWeek: Number(weeklyEarningsRow?.usd_earned_week ?? 0),
    purchaseCountToday: Number(purchasesRow?.purchase_count_today ?? 0),
    purchaseUsdToday: Number(purchasesRow?.purchase_usd_today ?? 0),
    pendingRedemptionsCount: Number(pendingRow?.pending_redemptions_count ?? 0),
    pendingRedemptionsUsd: Number(pendingRow?.pending_redemptions_usd ?? 0),
    bestPerformerName: bestPerformerRow?.name ?? null,
    bestPerformerSc: Number(bestPerformerRow?.net_sc ?? 0),
    claimStreakDays,
    dailyVelocityPct,
  };

  const trackedIds = initialData.casinos.map((casino) => casino.casino_id);
  const homeState = settingsRow?.home_state ?? null;
  const discoveryCacheKey = `dashboard-discovery:${user.userId}:${homeState ?? 'all'}:${trackedIds.join(',')}`;

  const discoveryRows = await safeDashboardQuery(
    'discovery',
    () =>
      getCached(discoveryCacheKey, 6 * 60 * 60 * 1000, async () =>
        query<{
          id: number;
          slug: string;
          name: string;
          tier: string | null;
          promoban_risk: string | null;
          daily_bonus_desc: string | null;
          redemption_speed_desc: string | null;
          has_live_games: boolean;
          has_affiliate_link: boolean;
          affiliate_link_url: string | null;
          intel_count: number | string | null;
          tracker_count: number | string | null;
        }>(
          `SELECT
            c.id,
            c.slug,
            c.name,
            c.tier_label AS tier,
            c.promoban_risk,
            c.daily_bonus_desc,
            c.redemption_speed_desc,
            c.has_live_games,
            c.has_affiliate_link,
            c.affiliate_link_url,
            COALESCE(intel.intel_count, 0) AS intel_count,
            COALESCE(pop.tracker_count, 0) AS tracker_count
          FROM casinos c
          LEFT JOIN (
            SELECT casino_id, COUNT(*)::int AS intel_count
            FROM discord_intel_items
            WHERE is_published = true
              AND (expires_at IS NULL OR expires_at > NOW())
            GROUP BY casino_id
          ) intel ON intel.casino_id = c.id
          LEFT JOIN (
            SELECT casino_id, COUNT(*)::int AS tracker_count
            FROM user_casino_settings
            WHERE removed_at IS NULL
            GROUP BY casino_id
          ) pop ON pop.casino_id = c.id
          WHERE c.source = 'admin'
            AND c.is_excluded = false
            AND ($1::int[] IS NULL OR NOT (c.id = ANY($1::int[])))
            AND (
              $2::text IS NULL
              OR EXISTS (
                SELECT 1
                FROM casino_state_availability csa
                WHERE csa.casino_id = c.id
                  AND csa.state_code = $2
                  AND csa.status IN ('available', 'operates_despite_restrictions')
              )
            )
          ORDER BY
            CASE c.tier_label
              WHEN 'S' THEN 0
              WHEN 'A' THEN 1
              WHEN 'B' THEN 2
              WHEN 'C' THEN 3
              ELSE 4
            END,
            COALESCE(intel.intel_count, 0) DESC,
            COALESCE(pop.tracker_count, 0) DESC,
            c.name ASC
          LIMIT 5`,
          [trackedIds.length > 0 ? trackedIds : null, homeState],
        ),
      ),
    [],
  );

  initialDiscovery = {
    homeState,
    casinos: discoveryRows.map((casino) => ({
      ...casino,
      intel_count: Number(casino.intel_count ?? 0),
      tracker_count: Number(casino.tracker_count ?? 0),
    })),
  };
}
---

<BaseLayout title="Dashboard | SweepsIntel" user={user} currentPath={Astro.url.pathname}>
  <div class="page-shell page-stack">
    <SessionGate
      client:load
      user={user}
      redirectTo="/dashboard"
      title="Save your dashboard"
      description="Enter your email the first time you want to save dashboard data."
    >
      {user && trackerError ? (
        <section class="surface-card" style="padding: 1.25rem; display: grid; gap: 0.75rem;">
          <h1 class="section-title" style="font-size: 1.5rem; margin: 0;">Dashboard unavailable</h1>
          <p class="muted" style="margin: 0; line-height: 1.6;">{trackerError}</p>
        </section>
      ) : null}
      {user ? (
        <DashboardTracker
          client:load
          user={user}
          initialData={initialData}
          initialSummary={initialSummary}
          initialDiscovery={initialDiscovery}
        />
      ) : null}
    </SessionGate>
  </div>
</BaseLayout>
