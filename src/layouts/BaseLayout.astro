---
import Analytics from '@vercel/analytics/astro';
import type { SessionUser } from '../lib/auth';
import Header from '../components/layout/Header';
import Footer from '../components/layout/Footer';

interface Props {
  title: string;
  description?: string;
  user?: SessionUser | null;
  currentPath?: string;
}

const {
  title,
  description = 'SweepsIntel',
  user = null,
  currentPath = '/',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#111827" />
    <link rel="manifest" href="/manifest.json" />
    <style>
      :root,
      html[data-theme='dark'] {
        color-scheme: dark;
        --bg-primary: #111827;
        --bg-secondary: #1f2937;
        --bg-tertiary: #374151;
        --text-primary: #f3f4f6;
        --text-secondary: #d1d5db;
        --text-muted: #9ca3af;
        --border: #374151;
        --accent-green: #10b981;
        --accent-red: #ef4444;
        --accent-yellow: #f59e0b;
        --accent-blue: #3b82f6;
        --progress-gradient: linear-gradient(90deg, #ef4444, #f59e0b, #10b981, #3b82f6);
        --color-primary: var(--accent-blue);
        --color-success: var(--accent-green);
        --color-warning: var(--accent-yellow);
        --color-danger: var(--accent-red);
        --color-muted: var(--text-muted);
        --color-ink: var(--text-primary);
        --color-surface: var(--bg-secondary);
        --color-surface-secondary: var(--bg-tertiary);
        --color-border: var(--border);
        --color-border-subtle: rgba(156, 163, 175, 0.24);
        --content-max-width: 1120px;
        --header-max-width: 1280px;
        --content-gutter: clamp(20px, 3vw, 40px);
        --page-bg:
          radial-gradient(circle at top, rgba(59, 130, 246, 0.12), transparent 30%),
          linear-gradient(180deg, var(--bg-primary) 0%, #0b1220 100%);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        font-size: 16px;
        color: var(--color-ink);
        background: var(--page-bg);
      }

      a {
        color: var(--color-primary);
      }

      button,
      input,
      select,
      textarea {
        font: inherit;
        color: var(--text-primary);
      }

      input,
      select,
      textarea {
        background: var(--bg-primary);
        border: 1px solid var(--color-border);
      }

      ::placeholder {
        color: var(--text-muted);
      }

      main {
        min-height: calc(100vh - 140px);
      }

      :global(.page-shell) {
        width: 100%;
        max-width: var(--content-max-width);
        padding-inline: var(--content-gutter);
        margin: 0 auto;
      }

      :global(.page-stack) {
        display: grid;
        gap: 2rem;
        padding: 2rem 0 4rem;
      }

      :global(.surface-card) {
        border-radius: 1.5rem;
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.28);
      }

      :global(.section-title) {
        margin: 0 0 1rem;
        font-size: clamp(1.5rem, 3vw, 2rem);
        letter-spacing: -0.04em;
      }

      :global(.muted) {
        color: var(--color-muted);
      }
    </style>
  </head>
  <body>
    <Header client:load user={user} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer />
    <Analytics />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }
    </script>
  </body>
</html>

